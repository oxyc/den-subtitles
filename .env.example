# den-subtitles — addon-level configuration (per-user LLM keys ride in the install URL, not here).

# HTTP port.
PORT=8093

# Where translated/synced SRTs are cached (also holds the sync scratch dir).
CACHE_DIR=/cache

# Cache byte budget (SRTs are tiny; 256 MB holds thousands of films). Default 256 MiB.
# CACHE_MAX_BYTES=268435456

# Fixed public origin used to build the /subtitle and /translate URLs handed back to the app.
# RECOMMENDED in production: when unset, the origin is derived from the (client-controlled) Host /
# X-Forwarded-Host header — sanitized to a safe charset, but still attacker-influenced. Setting this
# pins the origin and removes that path entirely.
# PUBLIC_BASE_URL=https://subs.example.com

# Note: there are NO user credentials here. Both the OpenSubtitles key and the LLM key are BYOK and
# entered per-install at /configure (they ride in the addon URL, stored in the Den Keychain).

# Sealed config-in-URL (den-scout/docs/SEALED-CONFIG.md): set this and /configure seals the config to
# it (crypto_box_seal) so the BYOK keys are never plaintext in the URL. A base64 32-byte X25519 private
# key — generate with:  head -c 32 /dev/urandom | base64  — and BACK IT UP (losing it breaks sealed
# installs). Unset = sealed disabled, legacy plaintext URLs still work. SUBS_CONFIG_KEYS_PREV holds
# comma-separated prior keys so you can rotate without breaking existing installs.
# SUBS_CONFIG_KEY=
# SUBS_CONFIG_KEYS_PREV=

# Binary paths (the container image places them here; override for a local run).
# ALASS_PATH=alass
# FFSUBSYNC_PATH=ffsubsync
